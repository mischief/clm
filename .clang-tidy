Checks: >
  bugprone-*,
  cert-err34-c,
  clang-analyzer-*,
  misc-misplaced-const,
  misc-redundant-expression,
  portability-*,
  -bugprone-easily-swappable-parameters,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -clang-analyzer-unix.Malloc

HeaderFilterRegex: '.*'
FormatStyle: file
